{
  "manifest_version": 3,
  "name": "OpenClaw Browser Relay",
  "version": "1.0.0",
  "description": "Connect browser tabs to OpenClaw for automation",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5003/*",
    "http://127.0.0.1:5003/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
