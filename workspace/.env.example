# 短剧选题交付智能体 - 环境配置示例

# ============================================
# 基础配置
# ============================================

# 输出目录配置
DRAMA_OUTPUT_DIR=./deliverables
DRAMA_LOG_DIR=./logs

# 选题配置
DRAMA_TOPIC_COUNT=3
DRAMA_GENRE=女性向

# ============================================
# 云盘上传配置
# ============================================

# 启用云盘上传
cat > .env << 'EOF'
DRAMA_OUTPUT_DIR=./deliverables
DRAMA_LOG_DIR=./logs
CLOUD_DRIVE_ENABLED=true
CLOUD_DRIVE_TYPE=aliyun
MESSAGING_ENABLED=true
MESSAGING_CHANNEL=xianyu
EOF

# 然后加载环境变量：
source .env && bash scripts/run-drama-agent.sh
CLOUD_DRIVE_ENABLED=false

# 云盘类型: aliyun(阿里云盘), baidu(百度云盘), quark(夸克云盘)
CLOUD_DRIVE_TYPE=aliyun

# 自定义上传脚本路径（留空则使用内置逻辑）
CLOUD_UPLOAD_SCRIPT=

# 云盘目标文件夹
CLOUD_TARGET_FOLDER=/短剧选题交付

# ============================================
# 消息通知配置
# ============================================

# 启用消息通知
MESSAGING_ENABLED=false

# 消息渠道: xianyu(闲鱼), telegram, email
MESSAGING_CHANNEL=xianyu

# ============================================
# Telegram 配置（如使用 Telegram）
# ============================================

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# 邮件配置（如使用邮件通知）
# ============================================

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=短剧选题交付助手

# ============================================
# 阿里云盘 CLI 配置（推荐）
# ============================================

# 1. 安装 aliyunpan
# wget https://github.com/tickstep/aliyunpan/releases/latest/download/aliyunpan-linux-amd64.zip
# unzip aliyunpan-linux-amd64.zip
# chmod +x aliyunpan
# sudo mv aliyunpan /usr/local/bin/

# 2. 登录（交互式）
# aliyunpan login

# 3. 创建上传脚本 scripts/upload-to-aliyun.sh
# 内容见下方的 upload-scripts 部分

# ============================================
# 上传脚本示例
# ============================================

## 阿里云盘上传脚本 (scripts/upload-to-aliyun.sh)
# #!/bin/bash
# FILEPATH=$1
# FILENAME=$2
# TARGET_FOLDER="/短剧选题交付"
# 
# # 上传文件
# aliyunpan upload "$FILEPATH" "$TARGET_FOLDER/$FILENAME"
# 
# # 创建分享链接
# SHARE_RESULT=$(aliyunpan share add "$TARGET_FOLDER/$FILENAME")
# echo "$SHARE_RESULT"

## 百度云盘上传脚本 (scripts/upload-to-baidu.sh)
# #!/bin/bash
# FILEPATH=$1
# FILENAME=$2
# 
# # 使用 BaiduPCS-Go
# BaiduPCS-Go upload "$FILEPATH" "/短剧选题交付/"
# 
# # 创建分享链接（需要额外处理）
# echo "请手动创建分享链接"

## rclone 通用脚本 (scripts/upload-rclone.sh)
# #!/bin/bash
# FILEPATH=$1
# FILENAME=$2
# REMOTE_NAME=aliyundrive
# 
# rclone copy "$FILEPATH" "$REMOTE_NAME:/短剧选题交付/"
# echo "文件已上传"

# ============================================
# 使用方法
# ============================================

# 1. 复制此文件为 .env
# cp env.example .env

# 2. 编辑 .env 文件，填写你的配置

# 3. 加载环境变量并运行
# source .env && bash scripts/run-drama-agent.sh

# ============================================
# 自动化方案
# ============================================

# 方案1: Cron 定时检查（推荐）
# crontab -e
# */5 * * * * cd /workspace/projects/workspace && source .env && node scripts/order-listener.js --process-once >> logs/cron.log 2>&1

# 方案2: 持续监听（需要保持运行）
# nohup bash -c 'source .env && node scripts/order-listener.js' > logs/listener.log 2>&1 &

# 方案3: 手动触发
# source .env && bash scripts/run-drama-agent.sh --order-id=ORD_001 --buyer-id=BUYER_001
