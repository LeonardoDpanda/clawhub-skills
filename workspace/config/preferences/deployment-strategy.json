      "required_fields": ["目标", "假设", "验证方法", "退出条件", "预算上限"]
    },
    "level_3_execution": {
      "description": "执行环节策略",
      "records_location": "memory/strategies/execution/{task_id}/",
      "required_fields": ["执行方案", "预期结果", "时间节点", "风险点", "备选方案"]
    }
  },
  
  "evolution_log": [
